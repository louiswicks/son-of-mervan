# ============================================================
# Son of Mervan — required environment variables
# Copy this file to .env and fill in all values before running.
# ============================================================

# REQUIRED — JWT signing secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be stable across restarts; changing it invalidates all user sessions.
JWT_SECRET_KEY=

# REQUIRED — 32-byte base64 Fernet key for encrypting financial data at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Changing this makes all existing encrypted data permanently unreadable.
ENCRYPTION_KEY=

# REQUIRED in production — PostgreSQL connection string.
# Omit to fall back to SQLite (development only).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# If unset, verification links are printed to the console (dev mode).
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL used in email verification links.
FRONTEND_BASE_URL=https://yourdomain.com

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://louiswicks.github.io

# ── Cloudflare R2 Backups ─────────────────────────────────────────────────────
# Required for scripts/backup.py and scripts/restore.py
# Create an R2 bucket in the Cloudflare dashboard and generate an API token with
# Object Read & Write permissions.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=son-of-mervan-backups
# Email to notify on backup failure (requires SENDGRID_API_KEY above)
BACKUP_ALERT_EMAIL=

# ── Optional ──────────────────────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Email verification token TTL in minutes (default: 60)
EMAIL_VERIFY_TTL_MIN=60

# Set to "production" to enable HSTS and other prod-only security headers.
ENVIRONMENT=development
